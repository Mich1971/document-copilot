st"}], "texts": [{"self_ref": "#/texts/0", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "section_header", "prov": [{"page_no": 1, "bbox": {"l": 42.519684749999996, "t": 817.3895701900625, "r": 487.0436903065503, "b": 773.4095699403125, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 74]}], "orig": "MANUAL DE CUMPLIMIENTO NORMATIVO Y PREVENCIÓN DE LAVADO DE DINERO (PLD/FT)", "text": "MANUAL DE CUMPLIMIENTO NORMATIVO Y PREVENCIÓN DE LAVADO DE DINERO (PLD/FT)", "level": 1}, {"self_ref": "#/texts/1", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "text", "prov": [{"page_no": 1, "bbox": {"l": 48.51968475, "t": 754.4397352578126, "r": 191.76368474999998, "b": 745.4487352578125, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 27]}], "orig": "CLASIFICACIÓN: CONFIDENCIAL", "text": "CLASIFICACIÓN: CONFIDENCIAL"}, {"self_ref": "#/texts/2", "parent": {"$ref": "#/groups/0"}, "children": [], "content_layer": "body", "label": "text", "prov": [{"page_no": 1, "bbox": {"l": 42.519684749999996, "t": 714.5397352578125, "r": 122.04368474999997, "b": 705.5487352578125, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 17]}], "orig": "ID del Documento:", "text": "ID del Documento:"}, {"self_ref": "#/texts/3", "parent": {"$ref": "#/groups/0"}, "children": [], "content_layer": "body", "label": "text", "prov": [{"page_no": 1, "bbox": {"l": 122.04385500000001, "t": 714.5397352578125, "r": 225.399855, "b": 705.5487352578125, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 22]}], "orig": "FiduciaPay-PLD-2026-V1", "text": "FiduciaPay-PLD-2026-V1"}, {"self_ref": "#/texts/4", "parent": {"$ref": "#/groups/0"}, "children": [], "content_layer": "body", "label": "text", "prov": [{"page_no": 1, "bbox": {"l": 297.6377955, "t": 714.5397352578125, "r": 364.86779550000006, "b": 705.5487352578125, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 15]}], "orig": "Fecha de Vigor:", "text": "Fecha de Vigor:"}, {"self_ref": "#/texts/5", "parent": {"$ref": "#/groups/0"}, "children": [], "content_layer": "body", "label": "text", "prov": [{"page_no": 1, "bbox": {"l": 364.84043175, "t": 714.5397352578125, "r": 446.34443175000024, "b": 705.5487352578125, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 18]}], "orig": "1 de Enero de 2026", "text": "1 de Enero de 2026"}, {"self_ref": "#/texts/6", "parent": {"$ref": "#/groups/0"}, "children": [], "content_layer": "body", "label": "text", "prov": [{"page_no": 1, "bbox": {"l": 42.519684749999996, "t": 694.1397352578125, "r": 93.09068474999998, "b": 685.1487352578125, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 12]}], "orig": "Propietario:", "text": "Propietario:"}, {"self_ref": "#/texts/7", "parent": {"$ref": "#/groups/0"}, "children": [], "content_layer": "body", "label": "text", "prov": [{"page_no": 1, "bbox": {"l": 93.0729075, "t": 694.1397352578125, "r": 202.9989075, "b": 685.1487352578125, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 25]}], "orig": "Dirección de Cumplimiento", "text": "Dirección de Cumplimiento"}, {"self_ref": "#/texts/8", "parent": {"$ref": "#/groups/0"}, "children": [], "content_layer": "body", "label": "text", "prov": [{"page_no": 1, "bbox": {"l": 297.6377955, "t": 694.1397352578125, "r": 333.28679550000004, "b": 685.1487352578125, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 8]}], "orig": "Versión:", "text": "Versión:"}, {"self_ref": "#/texts/9", "parent": {"$ref": "#/groups/0"}, "children": [], "content_layer": "body", "label": "text", "prov": [{"page_no": 1, "bbox": {"l": 333.2781765, "t": 694.1397352578125, "r": 411.6231765000001, "b": 685.1487352578125, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 21]}], "orig": "1.0 (Edición Inicial)", "text": "1.0 (Edición Inicial)"}, {"self_ref": "#/texts/10", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "section_header", "prov": [{"page_no": 1, "bbox": {"l": 51.51968475, "t": 634.2898415755625, "r": 209.13168171899997, "b": 621.3028418253125, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 25]}], "orig": "1. Introducción y Alcance", "text": "1. Introducción y Alcance", "level": 1}, {"self_ref": "#/texts/11", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "text", "prov": [{"page_no": 1, "bbox": {"l": 42.519684749999996, "t": 605.3898530755625, "r": 552.7074219953064, "b": 563.3998538253124, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 299]}], "orig": "Este manual establece las políticas, medidas y procedimientos mínimos que FiduciaPay (la \"Fintech\") debe aplicar para prevenir, detectar y reportar actos u operaciones que puedan favorecer, prestar ayuda o auxilio a la comisión de delitos de Lavado de Dinero o Financiamiento al Terrorismo (PLD/FT).", "text": "Este manual establece las políticas, medidas y procedimientos mínimos que FiduciaPay (la \"Fintech\") debe aplicar para prevenir, detectar y reportar actos u operaciones que puedan favorecer, prestar ayuda o auxilio a la comisión de delitos de Lavado de Dinero o Financiamiento al Terrorismo (PLD/FT)."}, {"self_ref": "#/texts/12", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "text", "prov": [{"page_no": 1, "bbox": {"l": 42.519684749999996, "t": 548.3898530755625, "r": 552.679671996, "b": 522.3998535753125, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 221]}], "orig": "Este documento es de carácter estrictamente obligatorio y de lectura mandatoria para todo el personal interno, con especial énfasis en las áreas de Operaciones, Soporte al Cliente, Desarrollo de Negocio y Mesa de Control.", "text": "Este documento es de carácter estrictamente obligatorio y de lectura mandatoria para todo el personal interno, con especial énfasis en las áreas de Operaciones, Soporte al Cliente, Desarrollo de Negocio y Mesa de Control."}, {"self_ref": "#/texts/13", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "section_header", "prov": [{"page_no": 1, "bbox": {"l": 51.51968475, "t": 496.7398415755625, "r": 472.65467665125016, "b": 483.7528418253125, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 66]}], "orig": "2. Política de Conocimiento del Cliente (KYC - Know Your Customer)", "text": "2. Política de Conocimiento del Cliente (KYC - Know Your Customer)", "level": 1}, {"self_ref": "#/texts/14", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "text", "prov": [{"page_no": 1, "bbox": {"l": 42.519684749999996, "t": 467.8398530755625, "r": 552.6786719960248, "b": 425.8498538253126, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 270]}], "orig": "Antes de abrir cualquier cuenta transaccional o permitir el uso de la pasarela de pagos en producción, se debe completar   el   proceso   formal   de   identificación   y   verificación   del   usuario   conforme   a   los   siguientes   niveles determinados por riesgo:", "text": "Antes de abrir cualquier cuenta transaccional o permitir el uso de la pasarela de pagos en producción, se debe completar   el   proceso   formal   de   identificación   y   verificación   del   usuario   conforme   a   los   siguientes   niveles determinados por riesgo:"}, {"self_ref": "#/texts/15", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "section_header", "prov": [{"page_no": 1, "bbox": {"l": 42.519684749999996, "t": 406.03960594006253, "r": 236.33968915499986, "b": 395.0506056903125, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 37]}], "orig": "2.1 Niveles de Verificación de Cuenta", "text": "2.1 Niveles de Verificación de Cuenta", "level": 1}, {"self_ref": "#/texts/16", "parent": {"$ref": "#/groups/1"}, "children": [], "content_layer": "body", "label": "list_item", "prov": [{"page_no": 1, "bbox": {"l": 51.23916750000001, "t": 382.7398535755625, "r": 504.62805451199995, "b": 356.74985332531253, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 192]}], "orig": "Nivel 1 (Básico): Requiere únicamente correo electrónico verificado, número de teléfono móvil y una identificación oficial digitalizada (cédula de identidad, pasaporte o ID nacional válido). ·", "text": "Nivel 1 (Básico): Requiere únicamente correo electrónico verificado, número de teléfono móvil y una identificación oficial digitalizada (cédula de identidad, pasaporte o ID nacional válido). ·", "enumerated": false, "marker": ""}, {"self_ref": "#/texts/17", "parent": {"$ref": "#/groups/1"}, "children": [], "content_layer": "body", "label": "list_item", "prov": [{"page_no": 1, "bbox": {"l": 51.23916750000001, "t": 346.23985332556254, "r": 522.93783976125, "b": 304.24985332531253, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 275]}], "orig": "Nivel 2 (Intermedio): Requiere todos los datos del Nivel 1, más un comprobante de domicilio digitalizado (recibo de servicios públicos de luz, agua o internet con una antigüedad menor a 3 meses) y verificación biométrica facial mediante validación activa de prueba de vida. ·", "text": "Nivel 2 (Intermedio): Requiere todos los datos del Nivel 1, más un comprobante de domicilio digitalizado (recibo de servicios públicos de luz, agua o internet con una antigüedad menor a 3 meses) y verificación biométrica facial mediante validación activa de prueba de vida. ·", "enumerated": false, "marker": ""}, {"self_ref": "#/texts/18", "parent": {"$ref": "#/groups/1"}, "children": [], "content_layer": "body", "label": "list_item", "prov": [{"page_no": 1, "bbox": {"l": 51.23916750000001, "t": 293.73985332556254, "r": 519.5196732000002, "b": 251.74985332531253, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 287]}], "orig": "Nivel 3 (Avanzado / Corporativo): Requiere la totalidad de los datos del Nivel 2, además de una comprobación formal de ingresos legítimos (estados de cuenta bancarios de los últimos 3 meses) o acta constitutiva e identificación del Representante Legal para el caso de personas morales. ·", "text": "Nivel 3 (Avanzado / Corporativo): Requiere la totalidad de los datos del Nivel 2, además de una comprobación formal de ingresos legítimos (estados de cuenta bancarios de los últimos 3 meses) o acta constitutiva e identificación del Representante Legal para el caso de personas morales. ·", "enumerated": false, "marker": ""}, {"self_ref": "#/texts/19", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "section_header", "prov": [{"page_no": 1, "bbox": {"l": 51.51968475, "t": 226.08984132556247, "r": 315.8746796662499, "b": 213.10284157531248, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 42]}], "orig": "3. Límites Transaccionales y Restricciones", "text": "3. Límites Transaccionales y Restricciones", "level": 1}, {"self_ref": "#/texts/20", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "text", "prov": [{"page_no": 1, "bbox": {"l": 42.519684749999996, "t": 197.18985357556244, "r": 552.7336719946501, "b": 171.19985332531246, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 220]}], "orig": "Para mitigar el riesgo operativo y cumplir con la regulación financiera vigente, FiduciaPay aplica límites estrictos de fondeo, retiro y saldos máximos permitidos según el nivel de verificación del usuario en el sistema:", "text": "Para mitigar el riesgo operativo y cumplir con la regulación financiera vigente, FiduciaPay aplica límites estrictos de fondeo, retiro y saldos máximos permitidos según el nivel de verificación del usuario en el sistema:"}, {"self_ref": "#/texts/21", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "furniture", "label": "page_footer", "prov": [{"page_no": 1, "bbox": {"l": 42.519684749999996, "t": 32.3463099400625, "r": 171.2396887725001, "b": 24.354309690312448, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 33]}], "orig": "FiduciaPay FinTech - Confidencial", "text": "FiduciaPay FinTech - Confidencial"}, {"self_ref": "#/texts/22", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "furniture", "label": "page_footer", "prov": [{"page_no": 1, "bbox": {"l": 503.602341, "t": 32.3463099400625, "r": 552.7623425362497, "b": 24.354309690312448, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 13]}], "orig": "Página 1 de 3", "text": "Página 1 de 3"}, {"self_ref": "#/texts/23", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "text", "prov": [{"page_no": 2, "bbox": {"l": 56.76968475, "t": 649.3969400755625, "r": 541.4919581416875, "b": 607.0046693253125, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 266]}], "orig": "Nota Crítica de Sistema: Las transacciones que intenten superar los límites parametrizados en la tabla anterior serán rechazadas de manera automática por el backend de FastAPI y enviarán un código de error estructurado de tipo LIMIT_EXCEEDED en el payload de la API.", "text": "Nota Crítica de Sistema: Las transacciones que intenten superar los límites parametrizados en la tabla anterior serán rechazadas de manera automática por el backend de FastAPI y enviarán un código de error estructurado de tipo LIMIT_EXCEEDED en el payload de la API."}, {"self_ref": "#/texts/24", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "section_header", "prov": [{"page_no": 2, "bbox": {"l": 51.51968475, "t": 572.3446580755624, "r": 418.13267769975, "b": 559.3576583253125, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 55]}], "orig": "4. Detección de Operaciones Sospechosas y Alertamientos", "text": "4. Detección de Operaciones Sospechosas y Alertamientos", "level": 1}, {"self_ref": "#/texts/25", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "text", "prov": [{"page_no": 2, "bbox": {"l": 42.519684749999996, "t": 543.4446695755626, "r": 552.7856719933502, "b": 501.4546695753125, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 223]}], "orig": "La Mesa de Control y el Agente de Inteligencia de Monitoreo automatizado deben vigilar de forma continua aquellos patrones transaccionales que se desvíen significativamente del comportamiento histórico esperado del usuario.", "text": "La Mesa de Control y el Agente de Inteligencia de Monitoreo automatizado deben vigilar de forma continua aquellos patrones transaccionales que se desvíen significativamente del comportamiento histórico esperado del usuario."}, {"self_ref": "#/texts/26", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "section_header", "prov": [{"page_no": 2, "bbox": {"l": 42.519684749999996, "t": 481.6444216900625, "r": 282.01169019299977, "b": 470.65542144031247, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 47]}], "orig": "4.1 Criterios de Alertas Automáticas (Gatillos)", "text": "4.1 Criterios de Alertas Automáticas (Gatillos)", "level": 1}, {"self_ref": "#/texts/27", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "text", "prov": [{"page_no": 2, "bbox": {"l": 42.519684749999996, "t": 458.34466932556245, "r": 552.7276719947997, "b": 432.3546698253125, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 157]}], "orig": "Se generará un caso de revisión prioritaria de manera inmediata en el panel de cumplimiento cuando ocurra cualquiera de las siguientes condiciones de alerta:", "text": "Se generará un caso de revisión prioritaria de manera inmediata en el panel de cumplimiento cuando ocurra cualquiera de las siguientes condiciones de alerta:"}, {"self_ref": "#/texts/28", "parent": {"$ref": "#/groups/2"}, "children": [], "content_layer": "body", "label": "list_item", "prov": [{"page_no": 2, "bbox": {"l": 51.23916750000001, "t": 417.3446690755625, "r": 549.5884350539998, "b": 391.3546695753125, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 151]}], "orig": "Gatillo de Frecuencia: Un usuario realiza más de 8 transacciones de depósito en un periodo menor a 2 horas, independientemente del monto consolidado. ·", "text": "Gatillo de Frecuencia: Un usuario realiza más de 8 transacciones de depósito en un periodo menor a 2 horas, independientemente del monto consolidado. ·", "enumerated": false, "marker": ""}, {"self_ref": "#/texts/29", "parent": {"$ref": "#/groups/2"}, "children": [], "content_layer": "body", "label": "list_item", "prov": [{"page_no": 2, "bbox": {"l": 51.23916750000001, "t": 380.8446695755624, "r": 534.7496728192498, "b": 338.8546695753125, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 229]}], "orig": "Gatillo de Fraccionamiento (Estructuración): Un usuario realiza múltiples transferencias individuales de $9,900.00 USD o cantidades muy cercanas al límite regulatorio de reporte de $10,000.00 USD dentro de un lapso de 48 horas. ·", "text": "Gatillo de Fraccionamiento (Estructuración): Un usuario realiza múltiples transferencias individuales de $9,900.00 USD o cantidades muy cercanas al límite regulatorio de reporte de $10,000.00 USD dentro de un lapso de 48 horas. ·", "enumerated": false, "marker": ""}, {"self_ref": "#/texts/30", "parent": {"$ref": "#/groups/2"}, "children": [], "content_layer": "body", "label": "list_item", "prov": [{"page_no": 2, "bbox": {"l": 51.23916750000001, "t": 328.3446695755624, "r": 495.04776380025004, "b": 302.35466932531256, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 192]}], "orig": "Gatillo de Origen Geográfico: Acceso a la cuenta o transferencias iniciadas desde direcciones IP identificadas en la lista negra de países bajo monitoreo intensivo o no cooperantes del GAFI. ·", "text": "Gatillo de Origen Geográfico: Acceso a la cuenta o transferencias iniciadas desde direcciones IP identificadas en la lista negra de países bajo monitoreo intensivo o no cooperantes del GAFI. ·", "enumerated": false, "marker": ""}, {"self_ref": "#/texts/31", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "section_header", "prov": [{"page_no": 2, "bbox": {"l": 42.519684749999996, "t": 282.5444214400625, "r": 208.78468852874994, "b": 271.5554211903125, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 31]}], "orig": "4.2 Límite de Reporte Inmediato", "text": "4.2 Límite de Reporte Inmediato", "level": 1}, {"self_ref": "#/texts/32", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "text", "prov": [{"page_no": 2, "bbox": {"l": 42.519684749999996, "t": 259.24466907556246, "r": 552.7590800255998, "b": 217.25466982531248, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 314]}], "orig": "Toda operación individual o acumulada dentro de un bloque de 24 horas que sea igual o superior a $10,000.00 USD (diez mil dólares norteamericanos) o su equivalente exacto en moneda local, debe ser reportada de forma mandatoria al Oficial de Cumplimiento dentro de un plazo máximo improrrogable de 4 horas hábiles .", "text": "Toda operación individual o acumulada dentro de un bloque de 24 horas que sea igual o superior a $10,000.00 USD (diez mil dólares norteamericanos) o su equivalente exacto en moneda local, debe ser reportada de forma mandatoria al Oficial de Cumplimiento dentro de un plazo máximo improrrogable de 4 horas hábiles ."}, {"self_ref": "#/texts/33", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "section_header", "prov": [{"page_no": 2, "bbox": {"l": 51.51968475, "t": 191.59465782556254, "r": 414.2716777739997, "b": 178.60765807531254, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 56]}], "orig": "5. Protocolo para Personas Políticamente Expuestas (PEP)", "text": "5. Protocolo para Personas Políticamente Expuestas (PEP)", "level": 1}, {"self_ref": "#/texts/34", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "text", "prov": [{"page_no": 2, "bbox": {"l": 42.519684749999996, "t": 162.69466932556247, "r": 552.8209219924686, "b": 120.70466932531258, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 232]}], "orig": "Se consideran PEP a aquellas personas que desempeñan o han desempeñado funciones públicas destacadas (ej. Jefes de Estado, legisladores, oficiales militares de alta jerarquía, o miembros de comités directivos de partidos políticos).", "text": "Se consideran PEP a aquellas personas que desempeñan o han desempeñado funciones públicas destacadas (ej. Jefes de Estado, legisladores, oficiales militares de alta jerarquía, o miembros de comités directivos de partidos políticos)."}, {"self_ref": "#/texts/35", "parent": {"$ref": "#/groups/3"}, "children": [], "content_layer": "body", "label": "list_item", "prov": [{"page_no": 2, "bbox": {"l": 51.23916750000001, "t": 105.69466932556247, "r": 540.6475627237501, "b": 63.70466932531258, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 223]}], "orig": "Aprobación Obligatoria: La apertura de cuentas para clientes clasificados como PEP (o sus familiares directos hasta el segundo grado de consanguinidad) no podrá ser automatizada bajo ninguna circunstancia por el software. ·", "text": "Aprobación Obligatoria: La apertura de cuentas para clientes clasificados como PEP (o sus familiares directos hasta el segundo grado de consanguinidad) no podrá ser automatizada bajo ninguna circunstancia por el software. ·", "enumerated": false, "marker": ""}, {"self_ref": "#/texts/36", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "furniture", "label": "page_footer", "prov": [{"page_no": 2, "bbox": {"l": 42.519684749999996, "t": 32.3463099400625, "r": 171.2396887725001, "b": 24.354309690312448, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 33]}], "orig": "FiduciaPay FinTech - Confidencial", "text": "FiduciaPay FinTech - Confidencial"}, {"self_ref": "#/texts/37", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "furniture", "label": "page_footer", "prov": [{"page_no": 2, "bbox": {"l": 503.602341, "t": 32.3463099400625, "r": 552.7623425362497, "b": 24.354309690312448, "coord_origin": "BOTTOMLEFT"}, "charspan": [0, 13]}], "orig": "Página 2 de 3", "text": "Página 2 de 3"}], "pictures": [], "tables": [{"self_ref": "#/tables/0", "parent": {"$ref": "#/body"}, "children": [], "content_layer": "body", "label": "table", "prov": [{"page_no": 2, "bbox": {"l": 41.22489547729492, "t": 786.3628005981445, "r": 553.0191040039062, "b": 672.3111877441406, "coord_origin": "